# =============================================================================
# ReclaimFlow PH — Environment Variables Template
# Copy this file to .env and fill in all values before deploying.
# NEVER commit .env to version control.
# =============================================================================

# ── Node ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── Database ──────────────────────────────────────────────────────────────────
# MySQL-compatible connection string (Supabase Transaction Pooler or direct)
DATABASE_URL=mysql://user:password@host:3306/reclaimflow

# ── Authentication ────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret
OAUTH_SERVER_URL=https://your-oauth-server.example.com
VITE_APP_ID=your-app-id
VITE_OAUTH_PORTAL_URL=https://your-oauth-portal.example.com
OWNER_OPEN_ID=your-owner-open-id

# ── Supabase Storage ──────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── AI / Forge API (optional) ─────────────────────────────────────────────────
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=
VITE_FRONTEND_FORGE_API_KEY=

# ── Docker Compose ────────────────────────────────────────────────────────────
# Host port to expose (default: 3000)
HOST_PORT=3000
